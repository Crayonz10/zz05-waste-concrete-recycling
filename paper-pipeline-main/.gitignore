# Only track skills, agents, and docs
# Ignore everything else by default
*

# Track these
!.gitignore
!README.md
!assets/
!assets/*
!commands/
!commands/*.md
!agents/
!agents/*.md
!skills/
!skills/*/
!skills/*/*.md
!skills/**/*.tmpl
!skills/**/publishers/
!skills/**/publishers/*/
!skills/**/publishers/*/*.tmpl
!skills/**/*.sh.tmpl
!skills/**/*.json.tmpl
!skills/**/*.tex.tmpl
!skills/**/*.sh
!skills/**/*.tex
!skills/**/*.py
!skills/**/*.json
!config/
!config/**
!skills_pipeline.pdf
!skills_pipeline.tex

# Sensitive files — never track
CLAUDE.md
settings.json
settings.local.json
memory/

# Never track these even if unignored above
*.backup
cache/
debug/
file-history/
history.jsonl
ide/
paste-cache/
plans/
plugins/
projects/
session-env/
shell-snapshots/
stats-cache.json
statsig/
tasks/
telemetry/
todos/
backups/
mcp-scripts/
