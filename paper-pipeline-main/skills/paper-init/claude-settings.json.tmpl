{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/unicode-guard.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/latex-compile.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(//Users/zylen/Library/CloudStorage/Dropbox/**)",
      "Bash(cat:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(pdfinfo:*)",
      "WebSearch",
      "Bash(wc:*)",
      "Bash(git push:*)"
    ],
    "deny": [],
    "ask": []
  }
}
