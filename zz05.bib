@article{yenipazarli2019Incentives,
  title = {Incentives for Environmental Research and Development: {{Consumer}} Preferences, Competitive Pressure and Emissions Taxation},
  shorttitle = {Incentives for Environmental Research and Development},
  author = {Yenipazarli, Arda},
  year = 2019,
  month = jul,
  journal = {European Journal of Operational Research},
  volume = {276},
