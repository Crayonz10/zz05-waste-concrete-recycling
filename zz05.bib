@article{chen2025Exploring,
  title = {Exploring Sustainable Models for Green Express Packaging Recycling with Third-Party Involvement},
  author = {Chen, Wei and Kang, Zengrui and Zhang, Dongqing and Zheng, Kaiming},
  year = 2025,
  month = dec,
  journal = {Computers \& Industrial Engineering},
  volume = {210},
  pages = {111499},
  issn = {0360-8352},
  doi = {10.1016/j.cie.2025.111499},
  urldate = {2026-04-27},
  abstract = {The rapid growth of e-commerce has intensified environmental concerns related to express packaging waste, particularly due to the challenges of designing effective recycling systems involving third-party recyclers. While their participation enhances recycling capacity, it also introduces complexity in aligning stakeholder incentives and responsibilities. This study develops a game-theoretic model to evaluate three governance structures---direct third-party recycling (T), manufacturer-delegated recycling (LT), and logistics-delegated recycling (MT)---and examines their impact on green investment, recycling performance, and profit distribution. Results show that differentiated pricing is more effective when remanufacturing savings are high, favoring Model LT; in contrast, Model MT performs better under low savings. Model T yields the highest profits for third-party recyclers, while LT benefits manufacturers and logistics providers. Cost-sharing structures also play a decisive role in shaping both environmental outcomes and stakeholder incentives. These findings offer practical insights for designing efficient and sustainable recycling systems under decentralized governance.},
  keywords = {Express packaging,Green logistics,Recycling models,Third-party participation},
