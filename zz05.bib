@article{zhao2020Use,
  title = {Use of Recycled Concrete Aggregates from Precast Block for the Production of New Building Blocks: {{An}} Industrial Scale Study},
  shorttitle = {Use of Recycled Concrete Aggregates from Precast Block for the Production of New Building Blocks},
  author = {Zhao, Zengfeng and Courard, Luc and Groslambert, Sylvie and Jehin, Thomas and L{\'e}onard, Ang{\'e}lique and Xiao, Jianzhuang},
